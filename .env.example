# Переменные ниже подхватывает docker-compose; в контейнере они маппятся в TELEGRAM__BotToken и т.д.
TELEGRAM_BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN
# Для каналов часто это ID вида -1001234567890
TELEGRAM_CHANNEL_ID=-1001234567890

VK_ACCESS_TOKEN=PASTE_VK_ACCESS_TOKEN
# ID сообщества без минуса
VK_GROUP_ID=123456

# Необязательно (по умолчанию 5.199)
VK_API_VERSION=5.199

